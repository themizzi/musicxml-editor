{
  "name": "Debian Dev",
  "dockerFile": "Dockerfile",
  "mounts": [
    "source=${localWorkspaceFolder}/.opencode,target=/home/dev/.local/share/opencode,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.local/share/opencode/auth.json,target=/tmp/opencode-auth.json,type=bind,consistency=cached"
  ],
  "postStartCommand": "mkdir -p /home/dev/.local/share/opencode && rm -f /home/dev/.local/share/opencode/auth.json && ln -s /tmp/opencode-auth.json /home/dev/.local/share/opencode/auth.json"
}
